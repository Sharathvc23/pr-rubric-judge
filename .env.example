# Copy this file to .env and fill in real values. .env is gitignored --
# it will never be committed. run_once.sh sources it automatically if
# present.

# Required. The repo whose open PRs you're judging.
TARGET_REPO=owner/repo

# Required. Get your own key from https://console.anthropic.com -- run_once.sh
# uses `claude -p --bare`, which only ever reads this variable, never an
# interactive login, so this has to be a real key for unattended/cron runs.
ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides -- uncomment and edit if the defaults in config.py don't fit.
# TARGET_CLONE=./clone
# TARGET_REMOTE=upstream
# PHASE1_BRANCH_PATTERN=^.+$
# PHASE1_REQUIRED_BASE=main
# PR_JUDGE_MAX_WORKERS=3
# PR_JUDGE_MAX_BUDGET_USD=0.75
# PR_JUDGE_CLUSTER_MAX_BUDGET_USD=0.50
